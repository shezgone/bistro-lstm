{"nodes": [{"id": "readme_bistro_lstm", "label": "BISTRO-LSTM Project", "file_type": "document", "source_file": "README.md", "source_location": "L1-L5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Benchmarks whether a tiny 170K-parameter task-specific Transformer can compete with 91-200M parameter foundation models on Korean CPI YoY forecasting; results show the task-specific model wins on average OOS RMSE (0.556 vs 0.932+)."}, {"id": "readme_attentionlstmforecaster", "label": "AttentionLSTMForecaster", "file_type": "concept", "source_file": "README.md", "source_location": "L20-L27", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~327K param architecture: per-variable embedding, cross-variable MHA fusion (4 heads), 2-layer stacked LSTM (hidden=128), temporal attention decoder with learnable forecast queries, Gaussian NLL output head (mu + log_sigma) for probabilistic forecasts."}, {"id": "readme_task_specific_transformer", "label": "Task-Specific Transformer (170K)", "file_type": "concept", "source_file": "README.md", "source_location": "L11", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Best overall model: 0.556 RMSE on both 2023 and 2024 OOS despite being ~1000x smaller than foundation models, demonstrating task-specific small models can beat zero-shot foundation models."}, {"id": "readme_chronos_2", "label": "Chronos-2 (120M, Zero-shot)", "file_type": "concept", "source_file": "README.md", "source_location": "L13", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Strong on 2023 (0.536 RMSE) but degrades sharply on 2024 (1.327), suggesting zero-shot instability across regimes."}, {"id": "readme_bistro_moirai", "label": "BISTRO (Moirai 91M)", "file_type": "concept", "source_file": "README.md", "source_location": "L14", "source_url": null, "captured_at": null, "author": null, "contribut